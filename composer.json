{
    "name": "opencat/filter-html",
    "description": "HTML file filter for the OpenCAT Framework",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "require": {
        "php": "^8.2",
        "ext-dom": "*",
        "ext-libxml": "*",
        "opencat/core": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "OpenCat\\FilterHtml\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenCat\\FilterHtml\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        }
    ]
}
